# remember to link this file using 
# ln -sv ~/.cache/wal/colors-dunstrc ~/.config/dunst/dunstrc

[global]
    corner_radius = 15
    font = 'Hack Nerd Font Mono' 9
    format = "<b>%s</b>\n%b"
    frame_width = 1
    gap_size = 10
    icon_corner_radius = 6
    offset = (15, 50)
    origin = bottom-right
    progress_bar_corner_radius = 5

[urgency_low]
    background = "{background}d8"
    foreground = "{foreground}"
    frame_color = "{color7}"
    highlight = "{color7}"
    timeout = 5

[urgency_normal]
    background = "{background}d8"
    foreground = "{foreground}"
    frame_color = "{color1}"
    highlight = "{color1}"
    timeout = 10

[urgency_critical]
    background = "{color6}"
    foreground = "{foreground}"
    frame_color = "{color6}"
    highlight = "{color6}"
    timeout = 0
